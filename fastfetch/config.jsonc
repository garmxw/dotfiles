// 󰘧 by garmx

{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "source": "~/.local/share/ascii/my-arch.txt",
    "color": {
      "1": "bright_",
    },
    "padding": {
      "top": 2,
      "right": 3,
    },
  },
  "display": {
    "separator": " ",
  },
  "modules": [
    "break",
    "break",
    {
      "type": "title",
      "format": " {user-name}@{host-name}",
      "keyWidth": 10,
    },
    {
      "type": "separator",
      "string": "·· •· •· •· •· •· ··",
    },
    "break",
    {
      "type": "os",
      "key": " ",
      "keyColor": "33", // = color3
    },
    {
      "type": "kernel",
      "key": " ",
      "keyColor": "33",
    },
    {
      "type": "shell",
      "key": " ",
      "keyColor": "33",
    },
    {
      "type": "terminal",
      "key": " ",
      "keyColor": "33",
    },
    {
      "type": "cpu",
      "key": "󰻠 ",
      "keyColor": "33",
    },
    {
      "type": "gpu",
      "key": "󰢮 ",
      "keyColor": "33",
    },
    {
      "type": "memory",
      "key": "󰍛 ",
      "format": "{used}/{total}",
      "keyColor": "33",
    },
    {
      "type": "disk",
      "key": "󰋊 ",
      "format": "{size-used}/{size-total}",
      "keyColor": "33",
    },

    "break",
    "colors",
    "break",
    "break",
  ],
}
